# ─────────────────────────────────────────────────────────────────
# CLIENT-SIDE (exposed to the browser via Vite)
# Set these in Vercel project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─────────────────────────────────────────────────────────────────
# SERVER-SIDE (used by /api/notify and /api/inbound — never exposed)
# ─────────────────────────────────────────────────────────────────

# Resend API key — get one from https://resend.com (free tier)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address. Use the free .resend.app subdomain you get on signup,
# OR a verified custom domain. Format: alerts@<your-id>.resend.app
FROM_EMAIL=alerts@your-id.resend.app

# The bare domain that receives inbound emails. Same .resend.app subdomain.
REPLY_TO_DOMAIN=your-id.resend.app

# Public URL of the deployed site (used in email "Open Dashboard" link)
PUBLIC_SITE_URL=https://jhagadia-night-watch.vercel.app

# Supabase admin credentials for the inbound webhook to write feedback
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NOT the anon key
